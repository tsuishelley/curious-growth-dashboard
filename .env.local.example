# --- Firebase (client SDK) ---
# From Firebase Console > Project settings > General > Your apps > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase (admin SDK, server-only) ---
# From Firebase Console > Project settings > Service accounts > Generate new private key
# Paste the ENTIRE downloaded JSON file contents as a single-line string.
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=

# --- Cron protection ---
# Any long random string. Vercel automatically sends this as a Bearer token
# to /api/cron/sync when it matches an env var named CRON_SECRET.
CRON_SECRET=

# --- AI weekly insights (Anthropic / Claude) ---
# Powers the "AI Weekly Insights" summary at the top of each company tab.
# Get a key at console.anthropic.com. If unset, insights are simply skipped.
ANTHROPIC_API_KEY=

# --- GA4 + Search Console (shared service account across all portfolio companies) ---
# JSON key for a Google service account. Added as a Viewer on each portco's GA4
# property, and as a user on each portco's Search Console property (same account,
# both APIs support service-account auth this way).
GA4_SERVICE_ACCOUNT_JSON=

# --- Google Ads (shared OAuth credentials across all portfolio companies) ---
# Unlike GA4/Search Console, the Ads API can't use a simple service-account key —
# it needs a Developer Token (apply via Google Ads API Center) plus an OAuth
# client + refresh token for a Google account that has Ads access to each
# portco's account (typically via a manager/MCC account). See README for setup.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=     # your Manager (MCC) account ID, digits only

# --- Per-company credentials ---
# Only fill in what you currently have access to; missing values simply show
# as "not connected" in the dashboard instead of breaking the sync job.

# Convox (GA4 + PostHog + Search Console + Google Ads)
CONVOX_GA4_PROPERTY_ID=
CONVOX_POSTHOG_API_KEY=
CONVOX_POSTHOG_PROJECT_ID=
# CONVOX_POSTHOG_HOST=              # only if self-hosted PostHog
CONVOX_SEARCH_CONSOLE_SITE_URL=
CONVOX_GOOGLE_ADS_CUSTOMER_ID=

# Polymer (GA4 + PostHog + Search Console + Google Ads)
POLYMER_GA4_PROPERTY_ID=
POLYMER_POSTHOG_API_KEY=
POLYMER_POSTHOG_PROJECT_ID=
# POLYMER_POSTHOG_HOST=
POLYMER_SEARCH_CONSOLE_SITE_URL=
POLYMER_GOOGLE_ADS_CUSTOMER_ID=

# Buildfire (GA4 + HubSpot + Search Console + Google Ads)
BUILDFIRE_GA4_PROPERTY_ID=
BUILDFIRE_HUBSPOT_TOKEN=
BUILDFIRE_SEARCH_CONSOLE_SITE_URL=
BUILDFIRE_GOOGLE_ADS_CUSTOMER_ID=

# Avenue (nothing connected yet -- sources below are a placeholder assumption)
AVENUE_GA4_PROPERTY_ID=
AVENUE_POSTHOG_API_KEY=
AVENUE_POSTHOG_PROJECT_ID=
# AVENUE_POSTHOG_HOST=
AVENUE_SEARCH_CONSOLE_SITE_URL=
AVENUE_GOOGLE_ADS_CUSTOMER_ID=

# Uservoice (GA4 + HubSpot + Search Console + Google Ads)
USERVOICE_GA4_PROPERTY_ID=
USERVOICE_HUBSPOT_TOKEN=
USERVOICE_SEARCH_CONSOLE_SITE_URL=
USERVOICE_GOOGLE_ADS_CUSTOMER_ID=
